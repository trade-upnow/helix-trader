DATABASE_URL=sqlite+aiosqlite:///./helix.db
JWT_SECRET=replace-with-a-long-random-secret
# Optional. Leave empty for local use (derived from JWT_SECRET). Encrypts saved exchange keys in DB.
# Do not change after save-credentials unless you will re-save exchange credentials.
API_ENCRYPTION_KEY=
# Frontend / recommended login (not CLIENT_*)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
# Extra seed user for internal testing only — do not tell end users to use this for the web UI
CLIENT_USERNAME=client001
CLIENT_PASSWORD=ChangeMe123!
BOT_POLL_SECONDS=20
# Leave empty when OKX is reachable directly. Doctor/setup auto-try 7890 if needed.
EXCHANGE_PROXY_URL=
EXCHANGE_HTTP_PROXY=
EXCHANGE_HTTPS_PROXY=

# Agent / CLI / MCP (local only — never publish real values)
HELIX_API_BASE_URL=http://127.0.0.1:8000
HELIX_USERNAME=
HELIX_PASSWORD=
HELIX_ACCESS_TOKEN=
HELIX_EXCHANGE_API_KEY=
HELIX_EXCHANGE_API_SECRET=
HELIX_EXCHANGE_PASSPHRASE=
HELIX_ALLOW_LIVE_TRADING=false
HELIX_HTTP_TIMEOUT_SECONDS=30
